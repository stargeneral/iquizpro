rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Health check — live presenter ConnectionManager heartbeat
    // Reads the _health/check document to verify Firestore connectivity.
    // Document may not exist; a "not found" read still succeeds permission-wise.
    // -------------------------------------------------------------------------
    match /_health/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // Live sessions — created and managed by the presenter (authenticated user)
    // Audience members (may be unauthenticated) can read session/slide data.
    //
    // Rate-limiting note: Firestore Security Rules do not support rate limiting
    // natively.  Rate limiting for live sessions must be enforced at the
    // application layer or via Cloud Functions if needed.
    // -------------------------------------------------------------------------
    match /live_sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.presenterId == request.auth.uid;

      // Slides — read by audience, written by presenter only
      match /slides/{slideId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.presenterId == request.auth.uid;
      }

      // Participants — audience members join (may be unauthenticated)
      // Presenter can read all; participants write their own entry only.
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if true;  // audience may be unauthenticated
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      // Responses — audience submits answers (may be unauthenticated)
      // No overwrite: once a response is created, it cannot be updated
      // (except by the presenter who can delete it).
      match /responses/{responseId} {
        allow read: if request.auth != null;
        allow create: if true;  // audience may be unauthenticated
        allow update: if false; // immutable after submission
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.presenterId == request.auth.uid;
      }

      // Aggregations — updated by presenter, readable by all for live bar charts
      match /aggregations/{aggId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.presenterId == request.auth.uid;
      }
    }

    // -------------------------------------------------------------------------
    // Top-level legacy collections (flat structure from older presenter code)
    // Kept for backward-compatibility; responses are now immutable after create.
    // -------------------------------------------------------------------------

    match /participants/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /responses/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if false; // immutable after submission — prevents answer manipulation
      allow delete: if request.auth != null;
    }

    match /slides/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /aggregations/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // -------------------------------------------------------------------------
    // Local quizzes — each authenticated user owns their own quiz documents
    // -------------------------------------------------------------------------
    match /local_quizzes/{docId} {
      allow read, write: if request.auth != null
        && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // User data — each user can only access their own document and subcollections
    // -------------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // usage/{monthKey} — monthly AI generation counters (Cloud Functions write)
      match /usage/{monthKey} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only Cloud Functions write usage docs via Admin SDK
      }

      // quizHistory — read/write by owner
      match /quizHistory/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // subscription — read by owner; written only by Cloud Functions (Admin SDK bypasses rules)
      // Note: actual subscription data is stored as a MAP FIELD on users/{uid} (not this subcollection)
      match /subscription/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only stripeWebhook Cloud Function writes via Admin SDK
      }
    }

    // -------------------------------------------------------------------------
    // AI-generated quizzes — written by Cloud Functions, read by owner only
    // -------------------------------------------------------------------------
    match /generatedQuizzes/{quizId} {
      allow read: if request.auth != null
        && resource != null
        && resource.data.uid == request.auth.uid;
      allow write: if false; // Only Cloud Functions create/delete via Admin SDK
    }

    // -------------------------------------------------------------------------
    // Session archive — written by presenter on session end
    // Any authenticated user can read (admin analytics page reads all sessions).
    // Write/delete restricted to the document owner (presenterId == uid).
    // -------------------------------------------------------------------------
    match /sessionArchive/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.presenterId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.presenterId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Daily leaderboard — each authenticated user writes their own score entry
    // Public read so the top-10 table is visible to all visitors.
    // -------------------------------------------------------------------------
    match /dailyLeaderboard/{date}/scores/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // -------------------------------------------------------------------------
    // Quiz statistics — play counts and aggregate answer distributions
    // Written by frontend (any visitor) so play counts are tracked for guests.
    //
    // Security design:
    //   - Public read: powers popular quizzes carousel and "how others answered"
    //   - Write restricted to known numeric fields only; prevents arbitrary injection
    //   - Allowed fields: playCount, updatedAt, q{N}o{N} (answer distribution keys)
    //
    // Rate-limiting note: Firestore rules cannot enforce per-user rate limits.
    // If abuse occurs, move play-count increment to a Cloud Function that can
    // enforce limits via Firestore transaction or Realtime Database throttle.
    // -------------------------------------------------------------------------
    match /quizStats/{topicId} {
      allow read: if true;

      // Create: all fields must be from the allowed set
      allow create: if request.resource.data.keys().hasOnly(
        ['playCount', 'updatedAt'].concat(
          request.resource.data.keys().filter(k, k.matches('^q[0-9]+o[0-9]+$'))
        )
      );

      // Update: only allowed fields may change; all changed values must be numbers
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(
          ['playCount', 'updatedAt'].concat(
            request.resource.data.keys().filter(k, k.matches('^q[0-9]+o[0-9]+$'))
          )
        );
    }

  }
}
